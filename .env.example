# Volatility3 IOC Extraction - Environment Configuration

# =============================================================================
# REQUIRED: Threat Intelligence API Keys
# =============================================================================

# VirusTotal API Key (https://www.virustotal.com/gui/my-apikey)
VT_API_KEY=your_virustotal_api_key_here

# AbuseIPDB API Key (https://www.abuseipdb.com/account/api)
ABUSEIPDB_KEY=your_abuseipdb_api_key_here

# =============================================================================
# OPTIONAL: Infrastructure Configuration
# =============================================================================

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# PostgreSQL Configuration
DATABASE_URL=postgresql://volatility:volatility_password@postgres:5432/volatility
POSTGRES_USER=volatility
POSTGRES_PASSWORD=volatility_password
POSTGRES_DB=volatility

# =============================================================================
# OPTIONAL: Server Configuration
# =============================================================================

# MCP Server
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_TRANSPORT=http

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# OPTIONAL: Analysis Configuration
# =============================================================================

# Maximum dump file size (bytes)
MAX_DUMP_SIZE=68719476736

# Plugin execution timeout (seconds)
PLUGIN_TIMEOUT=600

# Maximum concurrent plugin executions
MAX_CONCURRENT_PLUGINS=3

# Cache TTL (seconds)
CACHE_TTL=86400

# Threat intel cache TTL (seconds)
THREAT_INTEL_CACHE_TTL=21600

# =============================================================================
# OPTIONAL: Security Configuration
# =============================================================================

# Allowed dump directories (comma-separated)
ALLOWED_DUMP_DIRS=/app/data/dumps,/data/dumps

# Enable rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_PERIOD=60

# =============================================================================
# OPTIONAL: Paths Configuration
# =============================================================================

# Data directories
DUMPS_DIR=/app/data/dumps
SYMBOLS_DIR=/app/data/symbols
REPORTS_DIR=/app/data/reports
CACHE_DIR=/app/data/cache